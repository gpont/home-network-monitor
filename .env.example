# Home Network Monitor - Environment Variables
PORT=3201
DB_PATH=/app/data/monitor.db

# Custom ping targets (comma-separated, format: host:label)
# PING_TARGETS=192.168.1.1:Router,8.8.8.8:Google

# Custom DNS servers (comma-separated, format: ip:label)
# DNS_SERVERS=8.8.8.8:Google,1.1.1.1:Cloudflare

# Custom HTTP targets (comma-separated URLs)
# HTTP_TARGETS=https://www.google.com,https://github.com

# SSL certificate check hosts (comma-separated)
SSL_HOSTS=google.com,cloudflare.com,github.com

# Optional iperf3 server for bandwidth testing
# IPERF3_SERVER=192.168.1.100
