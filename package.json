{
  "name": "home-network-monitor",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "DB_PATH=./backend/data/dev.db PORT=3001 bun run --watch backend/src/index.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "build": "vite build --config frontend/vite.config.ts",
    "typecheck": "tsc --noEmit -p backend/tsconfig.json"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.0",
    "speedtest-net": "^2.2.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@types/bun": "latest",
    "bun": "latest",
    "chart.js": "^4.4.0",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.30.0",
    "svelte": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  }
}
